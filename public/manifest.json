{
  "manifest_version": 3,
  "name": "Clipcipe",
  "version": "0.1.0",
  "description": "Clip web pages to Markdown using per-site templates.",
  "permissions": ["storage", "scripting", "sidePanel", "activeTab", "alarms", "tabs"],
  "optional_permissions": [],
  "host_permissions": [],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Clipcipe"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
