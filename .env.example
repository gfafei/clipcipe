# Base URL of the backend that stores templates and clipped content.
# See PLAN.md's "REST API contract" section for the endpoints this extension expects
# (GET/POST /templates, PUT/DELETE /templates/:id, POST /clips).
# Copy this file to .env and fill in a real value, then rebuild — Vite inlines
# VITE_-prefixed vars into the bundle at build time, so changes require a rebuild.
VITE_API_BASE_URL=http://localhost:3000
